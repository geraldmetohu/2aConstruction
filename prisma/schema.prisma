generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id
  email        String
  firstName    String
  lastName     String
  profileImage String
  createdAt    DateTime? @default(now()) @db.Timestamp(6)
}

model Project {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String
  status      ProjectStatus
  images      String[]
  category    Category
  isFeatured  Boolean?      @default(false)
  createdAt   DateTime?     @default(now()) @db.Timestamp(6)
}

model Banner {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  subtitle    String?
  ctaText     String?
  ctaHref     String?
  imageString String
  createdAt   DateTime? @default(now()) @db.Timestamp(6)
}

model BeforeAfter {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title             String
  imageStringBefore String
  imageStringAfter  String
  createdAt         DateTime? @default(now()) @db.Timestamp(6)
}

model Contact {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  email       String
  phone       String
  role        Role
  description String
  address     String
  price       String
  createdAt   DateTime? @default(now()) @db.Timestamp(6)
}

model HeroVideo {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title     String
  subtitle  String?
  videoUrl  String
  posterUrl String?
  ctaText   String?
  ctaHref   String?
  isActive  Boolean?  @default(true)
  createdAt DateTime? @default(now()) @db.Timestamp(6)
}

enum ProjectStatus {
  draft
  published
  archived
}

enum Category {
  general
  refurbishment
  loft
  extention
  roof
  painting
  flooring
  plumbing
  electrical
}

enum Role {
  client
  painter
  groundwork
  scaffolding
  roofer
  carpetner
  plaster
  plasterboard
  electric
  plumbing
  gas
  bricklayer
  labour
  materials
  skip
  architect
  other
}
